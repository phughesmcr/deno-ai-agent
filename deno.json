{
  "name": "@phughesmcr/deno-ai-agent",
  "version": "0.0.1",
  "license": "MIT",
  "lock": true,
  "exports": "./main.ts",
  "nodeModulesDir": "auto",
  "minimumDependencyAge": "P2D",
  "publish": {
    "include": [
      "README.md",
      "LICENSE",
      "main.ts",
      "src/**/*.ts"
    ],
    "exclude": [
      "example/**",
      "bench/**",
      "test/**",
      ".github/**",
      ".vscode/**",
      ".cursor/**",
      ".claude/**"
    ]
  },
  "test": {
    "include": ["test/**/*.test.ts"]
  },
  "bench": {
    "include": ["bench/**/*.bench.ts"]
  },
  "compilerOptions": {
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "lib": [
      "esnext",
      "deno.ns",
      "deno.unstable",
      "deno.worker",
      "webworker",
      "webworker.asynciterable",
      "webworker.importscripts",
      "webworker.iterable"
    ],
    "module": "esnext",
    "noErrorTruncation": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "verbatimModuleSyntax": true
  },
  "fmt": {
    "bracePosition": "sameLine",
    "indentWidth": 2,
    "lineWidth": 120,
    "newLineKind": "lf",
    "nextControlFlowPosition": "sameLine",
    "operatorPosition": "sameLine",
    "proseWrap": "always",
    "quoteProps": "consistent",
    "semiColons": true,
    "singleQuote": false,
    "trailingCommas": "onlyMultiLine",
    "useBraces": "whenNotSingleLine",
    "useTabs": false,
    "exclude": ["*.md", "**/*.md", ".silas/**", "LICENSE"]
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended",
        "jsr"
      ],
      "include": [
        "default-param-last",
        "explicit-function-return-type",
        "explicit-module-boundary-types",
        "no-await-in-sync-fn",
        "no-console",
        "no-const-assign",
        "no-eval",
        "no-non-null-asserted-optional-chain",
        "no-sync-fn-in-async-fn",
        "no-throw-literal",
        "no-top-level-await",
        "no-undef",
        "no-useless-rename",
        "prefer-ascii",
        "single-var-declarator"
      ]
    }
  },
  "tasks": {
    "test": "deno test --unstable-kv --allow-read --allow-write --allow-run --allow-env=WS_NO_BUFFER_UTIL,WS_NO_UTF_8_VALIDATE,NODE_ENV,LOG_LEVEL,LMSTUDIO_IMAGE_TEST,DENO_TEST_PERMISSION_BROKER,HOME,TELEGRAM_BOT_TOKEN,TELEGRAM_ADMIN_ID,TELEGRAM_BOT_ID,MODEL,CONTEXT_LENGTH,BOT_NAME,WORKSPACE_PATH,OTEL_DENO,OTEL_SERVICE_NAME,OTEL_EXPORTER_OTLP_ENDPOINT,OTEL_EXPORTER_OTLP_PROTOCOL,DENO_PERMISSION_BROKER_PATH,SILAS_PERMISSION_CONTROL_PATH,PERMISSION_PROMPT_TIMEOUT_MS,REASONING_ENABLED,REASONING_ACT_PARSING,REASONING_START,REASONING_END,KEEP_THINKING,PREPEND_SYSTEM_PROMPT,DRAFT_MODEL,MAX_PREDICTION_ROUNDS,WHISPER_CPP_BIN,WHISPER_CPP_MODEL,WHISPER_CPP_LANGUAGE,TELEGRAM_AUDIO_TRANSCRIPTION test/**/*.test.ts",
    "test:broker": "DENO_TEST_PERMISSION_BROKER=1 deno test --allow-read --allow-write --allow-run --allow-net --allow-env test/permission-broker/daemon.integration.test.ts",

    "broker": "deno run --allow-net --allow-read --allow-write --allow-env src/permission-broker/daemon-entry.ts",
    "broker:only": "bash scripts/start-broker.sh",
    "start:unsafe": "deno run --unstable-kv --env-file=.env --allow-read --allow-write --allow-run --allow-net --allow-env main.ts",
    "start:unsafe:otel": "OTEL_DENO=true OTEL_SERVICE_NAME=deno-ai-agent deno run --unstable-kv --env-file=.env --allow-read --allow-write --allow-run --allow-net --allow-env main.ts",
    "start:unsafe:otel:console": "OTEL_DENO=true OTEL_SERVICE_NAME=deno-ai-agent OTEL_EXPORTER_OTLP_PROTOCOL=console deno run --unstable-kv --env-file=.env --allow-read --allow-write --allow-run --allow-net --allow-env main.ts",
    "agent:broker": "bash scripts/start-agent-with-broker.sh",
    "agent:broker:otel": "bash scripts/start-agent-with-broker-otel.sh",
    "start:all": "bash scripts/start-with-broker.sh",
    "start:all:otel": "bash scripts/start-with-broker-otel.sh",
    "start": "bash scripts/start-with-broker.sh",
    "start:otel": "bash scripts/start-with-broker-otel.sh",

    "check:docs": "deno doc --unstable-kv --lint main.ts src/agent/lmstudio.ts src/agent/workspace.ts src/agent/context/compactor.ts src/agent/context/persisted-message.ts src/agent/context/session-store.ts src/agent/context/session.ts src/shared/approval.ts src/shared/log.ts src/shared/otel.ts src/telegram/commands.ts src/telegram/telegram.ts src/telegram/telegram-reply.ts src/telegram/todo-list-format.ts src/permission-broker/version.ts",
    "check:fmt": "deno fmt --check",
    "check:lint": "deno lint",
    "check:types": "deno check --unstable-kv --allow-import main.ts src/**/*.ts test/**/*.test.ts bench/**/*.ts",
    "ci": "CI=1 deno task check:fmt && deno task check:lint && deno task check:types && deno task check:docs && deno task test",

    "otel:collector:install": "bash otel/download-otelcol.sh",
    "otel:collector:jaeger": "./otel/otelcol --config=otel/otel-collector.jaeger.yaml",
    "otel:jaeger:install": "bash otel/download-jaeger.sh",
    "otel:jaeger": "./otel/jaeger-all-in-one --collector.otlp.http.host-port=:14318"
  },
  "imports": {
    "@std/async/debounce": "jsr:@std/async/debounce",
    "@std/front-matter": "jsr:@std/front-matter@^1.0.9",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.0",
    "@std/streams": "jsr:@std/streams@^1.0.12",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.1",
    "@lmstudio/sdk": "npm:@lmstudio/sdk@^1.5.0",
    "@std/yaml": "jsr:@std/yaml@^1.1.1",
    "grammy": "npm:grammy@^1.43.0",
    "@grammyjs/runner": "npm:@grammyjs/runner@^2.0.3",
    "grammy-questions": "npm:grammy-questions@0.1.9",
    "zod": "npm:zod@^4.4.3",
    "@modelcontextprotocol/sdk/client": "npm:@modelcontextprotocol/sdk@^1.29.0/client",
    "@modelcontextprotocol/sdk/client/stdio": "npm:@modelcontextprotocol/sdk@^1.29.0/client/stdio.js",
    "@modelcontextprotocol/sdk/client/streamableHttp": "npm:@modelcontextprotocol/sdk@^1.29.0/client/streamableHttp.js",
    "@modelcontextprotocol/sdk/types": "npm:@modelcontextprotocol/sdk@^1.29.0/types.js",
    "@modelcontextprotocol/sdk/shared/transport": "npm:@modelcontextprotocol/sdk@^1.29.0/shared/transport.js",
    "@modelcontextprotocol/sdk/shared/stdio": "npm:@modelcontextprotocol/sdk@^1.29.0/shared/stdio.js",
    "ajv": "npm:ajv@^8.17.1"
  },
  "unstable": [
    "kv",
    "cron"
  ]
}
