TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_BOT_ID=

DRAFT_MODEL=your-draft-model-id
# Vision-language model (VLM) required for Telegram photos; e.g. qwen2-vl-2b-instruct
MODEL=your-lmstudio-vlm-id
CONTEXT_LENGTH=65536
# Tool-loop rounds for model.act() (default 30; Gemma models auto-default to 1)
# MAX_PREDICTION_ROUNDS=30

REASONING_ENABLED=true
# LM Studio model.act() reasoningParsing. Set true for Qwen/DeepSeek; leave false for Gemma and other non-reasoning Jinja templates.
REASONING_ACT_PARSING=false
REASONING_START=<think>
REASONING_END=</think>
# When false, strip reasoning from session JSONL, compaction checkpoints, and subagent results.
# Main-turn Telegram still uses raw model text and existing Markdown formatting (not affected).
KEEP_THINKING=true

PREPEND_SYSTEM_PROMPT=<|think|>

BOT_NAME=Silas
WORKSPACE_PATH=.silas

# Permission broker (default path for `deno task start` / `deno task start:otel`)
SILAS_BROKER_LISTEN_PATH=/tmp/silas-perm.sock
DENO_PERMISSION_BROKER_PATH=/tmp/silas-perm.sock
SILAS_PERMISSION_CONTROL_PATH=/tmp/silas-perm-control.sock
SILAS_PERMISSION_RUN_PROMPTS=1
SILAS_PROJECT_ROOT=.
# PERMISSION_PROMPT_TIMEOUT_MS=120000

# Optional: OpenTelemetry (see otel/README.md)
# OTEL_DENO=true
# OTEL_SERVICE_NAME=deno-ai-agent
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Optional: debug logs for context/token stats (no message bodies)
# LOG_LEVEL=debug
