TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_BOT_ID=

MODEL=your-lmstudio-model-id
CONTEXT_LENGTH=65536

BOT_NAME=Silas
WORKSPACE_PATH=.silas

# Permission broker (two terminals: `deno task broker:only` then `deno task agent:broker:otel`)
# Or one terminal: `deno task start:all` / `deno task start:all:otel`
SILAS_BROKER_LISTEN_PATH=/tmp/silas-perm.sock
DENO_PERMISSION_BROKER_PATH=/tmp/silas-perm.sock
SILAS_PERMISSION_CONTROL_PATH=/tmp/silas-perm-control.sock
SILAS_PERMISSION_RUN_PROMPTS=1
SILAS_PROJECT_ROOT=.
# PERMISSION_PROMPT_TIMEOUT_MS=120000

# Optional: OpenTelemetry (see otel/README.md)
# OTEL_DENO=true
# OTEL_SERVICE_NAME=deno-ai-agent
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Optional: debug logs for context/token stats (no message bodies)
# LOG_LEVEL=debug
